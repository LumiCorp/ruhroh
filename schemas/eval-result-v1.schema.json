{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumicorp.github.io/ruhroh/schemas/eval-result-v1.schema.json",
  "title": "Ruhroh Eval Result v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "version",
    "status",
    "goalMet",
    "confidence",
    "reasons",
    "unmetCriteria",
    "evidenceRefs",
    "commandsRun",
    "artifacts",
    "finalSummary"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "ruhroh_eval_result_v1" },
    "status": { "enum": ["passed", "failed", "review", "infra_failed"] },
    "goalMet": { "type": "boolean" },
    "confidence": { "enum": ["low", "medium", "high"] },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unmetCriteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidenceRefs": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceRef" }
    },
    "commandsRun": {
      "type": "array",
      "items": { "$ref": "#/$defs/commandRecord" }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "finalSummary": { "type": "string" },
    "repairBrief": { "type": "string" },
    "criteriaResults": {
      "type": "array",
      "items": { "$ref": "#/$defs/criterionResult" }
    },
    "subscores": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "judge": { "$ref": "#/$defs/judge" },
    "judgeVotes": {
      "type": "array",
      "items": { "$ref": "#/$defs/judgeVote" }
    },
    "judgeAgreement": { "$ref": "#/$defs/judgeAgreement" }
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "ref"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" }
      }
    },
    "commandRecord": {
      "type": "object",
      "additionalProperties": true,
      "required": ["command", "exitCode", "summary"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "exitCode": { "type": "number" },
        "summary": { "type": "string" }
      }
    },
    "criterionResult": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "status": { "enum": ["passed", "failed", "review", "not_applicable"] },
        "score": { "type": "number" },
        "weight": { "type": "number", "minimum": 0 },
        "evidenceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "notes": { "type": "string" }
      }
    },
    "judge": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "judgeVote": {
      "type": "object",
      "additionalProperties": true,
      "required": ["judge", "status", "confidence", "rationale", "evidenceRefs"],
      "properties": {
        "judge": { "$ref": "#/$defs/judge" },
        "status": { "enum": ["passed", "failed", "review", "infra_failed"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "rationale": { "type": "string" },
        "evidenceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "weight": { "type": "number", "minimum": 0 }
      }
    },
    "judgeAgreement": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "voteCount": { "type": "number", "minimum": 0 },
        "unanimous": { "type": "boolean" },
        "statusCounts": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "majorityStatus": { "enum": ["passed", "failed", "review", "infra_failed"] },
        "dissentingJudges": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
