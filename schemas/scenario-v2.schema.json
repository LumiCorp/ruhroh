{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumicorp.github.io/ruhroh/schemas/scenario-v2.schema.json",
  "title": "Ruhroh Scenario v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "version",
    "id",
    "title",
    "tier",
    "kind",
    "userPromptPath",
    "run",
    "requires",
    "loop",
    "evaluation"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "ruhroh_scenario_v2" },
    "id": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "tier": { "enum": ["smoke", "nightly", "release"] },
    "kind": { "enum": ["real_user", "contract_stress"] },
    "metadata": { "$ref": "#/$defs/metadata" },
    "userPromptPath": { "type": "string", "minLength": 1 },
    "assets": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "run": {
      "type": "object",
      "additionalProperties": true,
      "required": ["timeoutSeconds"],
      "properties": {
        "mode": { "enum": ["build", "plan", "chat"] },
        "timeoutSeconds": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "requires": {
      "type": "object",
      "additionalProperties": true,
      "required": ["continuity", "tools", "network"],
      "properties": {
        "continuity": { "enum": ["native_session", "workspace_plus_transcript", "workspace_only"] },
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "network": { "type": "boolean" }
      }
    },
    "loop": {
      "type": "object",
      "additionalProperties": true,
      "required": ["defaultMaxIterations", "stopPolicy"],
      "properties": {
        "defaultMaxIterations": { "type": "number", "exclusiveMinimum": 0 },
        "stopPolicy": { "const": "goal_satisfied_or_max" }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode", "scenarioContext", "goalRubric", "evidenceGuidance"],
      "properties": {
        "mode": { "const": "agentic_goal_review" },
        "scenarioContext": { "$ref": "#/$defs/nonEmptyStringArray" },
        "goalRubric": { "$ref": "#/$defs/nonEmptyStringArray" },
        "evidenceGuidance": { "$ref": "#/$defs/nonEmptyStringArray" },
        "privateAssets": { "$ref": "#/$defs/nonEmptyStringArray" },
        "calibrationCases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id", "inputSummary", "expectedStatus", "rationale"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "inputSummary": { "type": "string", "minLength": 1 },
              "expectedStatus": { "enum": ["passed", "failed", "review"] },
              "rationale": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["scenarioVersion"],
      "properties": {
        "scenarioVersion": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "difficulty": { "enum": ["intro", "standard", "hard", "expert"] },
        "tags": { "$ref": "#/$defs/nonEmptyStringArray" },
        "visibility": { "enum": ["public", "private", "held_out"] },
        "expectedRuntimeSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "networkRationale": { "type": "string", "minLength": 1 },
        "contaminationNotes": { "type": "string", "minLength": 1 },
        "privateEvalRationale": { "type": "string", "minLength": 1 },
        "maintainers": { "$ref": "#/$defs/nonEmptyStringArray" },
        "changelog": { "$ref": "#/$defs/nonEmptyStringArray" },
        "lifecycle": {
          "type": "object",
          "additionalProperties": true,
          "required": ["status"],
          "properties": {
            "status": { "enum": ["active", "deprecated", "retired"] },
            "replacementId": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
            "reason": { "type": "string", "minLength": 1 },
            "sunsetAt": { "type": "string" }
          }
        }
      }
    }
  }
}
