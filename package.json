{
  "name": "@kestrel-agents/ruhroh",
  "version": "0.6.0-beta.0",
  "description": "Realistic user-request benchmarks for coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LumiCorp/ruhroh.git"
  },
  "homepage": "https://lumicorp.github.io/ruhroh/",
  "bugs": {
    "url": "https://github.com/LumiCorp/ruhroh/issues"
  },
  "keywords": [
    "ruhroh",
    "harbor",
    "benchmark",
    "evaluation",
    "agents",
    "coding-agents",
    "outcomes",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./schemas/benchmark-claim-v1.schema.json": "./schemas/benchmark-claim-v1.schema.json",
    "./schemas/benchmark-summary-v1.schema.json": "./schemas/benchmark-summary-v1.schema.json",
    "./schemas/claim-index-v1.schema.json": "./schemas/claim-index-v1.schema.json",
    "./schemas/eval-calibration-report-v1.schema.json": "./schemas/eval-calibration-report-v1.schema.json",
    "./schemas/eval-result-v1.schema.json": "./schemas/eval-result-v1.schema.json",
    "./schemas/loop-result-v1.schema.json": "./schemas/loop-result-v1.schema.json",
    "./schemas/publish-bundle-v1.schema.json": "./schemas/publish-bundle-v1.schema.json",
    "./schemas/publish-check-v1.schema.json": "./schemas/publish-check-v1.schema.json",
    "./schemas/run-manifest-v1.schema.json": "./schemas/run-manifest-v1.schema.json",
    "./schemas/run-plan-v1.schema.json": "./schemas/run-plan-v1.schema.json",
    "./schemas/rerun-ledger-v1.schema.json": "./schemas/rerun-ledger-v1.schema.json",
    "./schemas/scenario-v2.schema.json": "./schemas/scenario-v2.schema.json",
    "./schemas/suite-v1.schema.json": "./schemas/suite-v1.schema.json",
    "./schemas/workspace-summary-v1.schema.json": "./schemas/workspace-summary-v1.schema.json"
  },
  "bin": {
    "ruhroh": "./dist/cli.js"
  },
  "files": [
    "assets/**/*",
    "dist",
    "python/**/*.py",
    "python/**/*.sh",
    "scenarios/**/*",
    "schemas/**/*",
    "suites/**/*",
    "examples/**/*",
    "docs/**/*.md",
    "!docs/.vitepress/**",
    "!docs/public/**",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "pnpm run clean && tsc -p tsconfig.json && node --input-type=module -e \"import { chmodSync } from 'node:fs'; chmodSync('dist/cli.js', 0o755);\"",
    "smoke:package": "node scripts/package-smoke.mjs",
    "docs:samples": "node scripts/generate-docs-samples.mjs",
    "docs:samples:check": "node scripts/check-docs-samples.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "pnpm run build",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitepress": "^1.6.4"
  },
  "packageManager": "pnpm@9.12.3"
}
